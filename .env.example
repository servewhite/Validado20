# Variáveis de Ambiente para PayEvo PIX Integration
# Copie este arquivo para .env e preencha com suas credenciais

# Credenciais PayEvo (obtenha em https://payevo.com.br)
PAYEVO_API_KEY=sua_chave_api_aqui
PAYEVO_MERCHANT_ID=seu_merchant_id_aqui

# Configurações opcionais
PAYEVO_API_URL=https://api.payevo.com.br
PAYEVO_TIMEOUT=30000

# Notas:
# - Se estas variáveis não estiverem configuradas, a função funcionará em MODO DEMO
# - Em MODO DEMO, retorna QR code simulado para testes
# - Para produção, é OBRIGATÓRIO configurar as variáveis reais
